NODE_ENV=production
PORT=3001

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# 32+ characters minimum in production
JWT_SECRET=replace-with-a-long-random-secret

# Frontend URL used in password reset emails
APP_URL=https://closer-frontend-mu.vercel.app

# Comma-separated list of allowed browser origins
CORS_ORIGINS=https://closer-frontend-mu.vercel.app,https://closerdebrief.vercel.app

# Request hardening
BODY_LIMIT=1mb
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AI_MAX=20

# AI
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_FALLBACK_MODELS=claude-3-7-sonnet-latest,claude-3-5-sonnet-latest

# Optional integrations
RESEND_API_KEY=
ZAPIER_SECRET=
ZAPIER_WEBHOOK_URL=
